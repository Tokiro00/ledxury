{
  "name": "mam-tailwind-theme",
  "version": "1.0.1",
  "description": "MAM Tailwind",
  "main": "./public/assets/js/main.js",
  "scripts": {
    "start": "cross-env NODE_OPTIONS=--openssl-legacy-provider NODE_ENV=development SERVER=true webpack --watch",
    "watch": "cross-env NODE_OPTIONS=--openssl-legacy-provider NODE_ENV=development webpack --watch",
    "dev": "cross-env NODE_OPTIONS=--openssl-legacy-provider NODE_ENV=development webpack",
    "prod": "cross-env NODE_OPTIONS=--openssl-legacy-provider NODE_ENV=production webpack",
    "build": "concurrently \"npm run prod\" \"npm run dev\""
  },
  "devDependencies": {
    "@babel/core": "^7.10.5",
    "@babel/polyfill": "^7.10.4",
    "@babel/preset-env": "^7.10.4",
    "@fullhuman/postcss-purgecss": "^2.3.0",
    "@tailwindcss/custom-forms": "^0.2.1",
    "autoprefixer": "^9.8.5",
    "babel-loader": "^8.1.0",
    "browser-sync": "^2.26.10",
    "browser-sync-webpack-plugin": "^2.2.2",
    "concurrently": "^5.2.0",
    "copy-webpack-plugin": "^6.0.3",
    "cross-env": "^7.0.2",
    "css-loader": "^3.6.0",
    "cssnano": "^4.1.10",
    "imagemin-webpack-plugin": "^2.4.2",
    "mini-css-extract-plugin": "^0.9.0",
    "postcss-loader": "^3.0.0",
    "resolve-url-loader": "^3.1.1",
    "style-loader": "^1.2.1",
    "tailwindcss": "^1.8.7",
    "uglifyjs-webpack-plugin": "^2.2.0",
    "webpack": "^4.43.0",
    "webpack-cli": "^3.3.12"
  },
  "dependencies": {
    "@glidejs/glide": "^3.4.1",
    "jquery": "^3.5.1",
    "lodash": "^4.17.20",
    "postcss-custom-properties": "^9.1.1",
    "postcss-import": "^12.0.1",
    "postcss-nested": "^4.2.3",
    "regenerator": "^0.14.7",
    "vue2-transitions": "^0.3.0",
    "xlsx": "^0.18.5"
  },
  "overrides": {
    "traverse": "0.6.7"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not ie <= 11"
  ],
  "engines": {
    "node": ">=10.5.0",
    "npm": ">=6.4.1"
  },
