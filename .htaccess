Options FollowSymLinks
<IfModule mod_rewrite.c>
    RewriteEngine on

    # Pass Authorization header to PHP
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # Fallback: SetEnvIf for XAMPP Windows
    SetEnvIf Authorization "(.*)" HTTP_AUTHORIZATION=$1

    # CORS preflight for API
    RewriteCond %{REQUEST_METHOD} OPTIONS
    RewriteRule ^api/ index.php?/$0 [L]

    # Serve PWA: resolve directories to index.html
    RewriteCond %{REQUEST_URI} /pwa/(.*/)?$
    RewriteCond %{DOCUMENT_ROOT}/pwa/$1index.html -f
    RewriteRule ^ /pwa/%1index.html [L]

    # Serve PWA static files directly
    RewriteCond %{REQUEST_URI} /pwa/
    RewriteCond %{REQUEST_FILENAME} -f
    RewriteRule ^ - [L]

    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    # Flag [B] re-escapa backreferences ($1) — sin esto, Apache 2.4.40+
    # rechaza URLs con espacios decodificados (ej: /search/carlos%20pe)
    # con error AH10411 "Rewritten query string contains spaces".
    RewriteRule ^(.*)$ index.php?/$1 [L,B]
</IfModule> 
 
<IfModule !mod_rewrite.c>
    ErrorDocument 404 /index.php
</IfModule>